# Optional: nur fuer KI-gestuetzte Formulierung von Mailentwuerfen
# und die Funktion "Automatisch mit KI ausfuellen".
# Ohne API-Key nutzt die App weiterhin Template-Entwuerfe.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_WEBSITE_MODEL=gpt-5.4-mini

# Optional: Gmail-Drafts erstellen, ohne E-Mails zu senden.
# Scope der App: https://www.googleapis.com/auth/gmail.compose
# Lege die OAuth-Client-Datei standardmaessig als credentials.json im Projektordner ab.
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=data/gmail_token.json
